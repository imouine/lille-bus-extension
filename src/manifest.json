{
  "manifest_version": 3,
  "name": "Lille Bus — Live Countdown",
  "version": "1.0.1",
  "description": "See minutes until your next Lille bus on the toolbar badge. Live data, multi-stop watchers, dark mode & more.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://data.lillemetropole.fr/*"],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_title": "Lille Bus — Live Countdown",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html"
}
